{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Azure Portal shared dashboard for the GitHub Copilot FinOps Simulator: cookieless Application Insights engagement + key product events. Deploy with scripts/analytics.ps1 or `az deployment group create`."
  },
  "parameters": {
    "appInsightsId": {
      "type": "string",
      "metadata": { "description": "Resource ID of the Application Insights component to query." }
    },
    "appInsightsName": {
      "type": "string",
      "defaultValue": "finops-copilot-ai",
      "metadata": { "description": "Display name of the Application Insights component (tile asset label)." }
    },
    "dashboardName": {
      "type": "string",
      "defaultValue": "finops-copilot-engagement"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "variables": {
    "scope": { "resourceIds": ["[parameters('appInsightsId')]"] }
  },
  "resources": [
    {
      "type": "Microsoft.Portal/dashboards",
      "apiVersion": "2020-09-01-preview",
      "name": "[parameters('dashboardName')]",
      "location": "[parameters('location')]",
      "tags": { "hidden-title": "FinOps Copilot — Engagement & Key Events" },
      "properties": {
        "lenses": [
          {
            "order": 0,
            "parts": [
              {
                "position": { "x": 0, "y": 0, "colSpan": 12, "rowSpan": 1 },
                "metadata": {
                  "inputs": [],
                  "type": "Extension/HubsExtension/PartType/MarkdownPart",
                  "settings": {
                    "content": {
                      "settings": {
                        "content": "## GitHub Copilot FinOps Simulator — engagement & key events\nCookieless Application Insights (no cookie / GDPR banner). Each tile shows the last 30 days. Terminal report: `npm run analytics`.",
                        "title": "",
                        "subtitle": ""
                      }
                    }
                  }
                }
              },
              {
                "position": { "x": 0, "y": 1, "colSpan": 8, "rowSpan": 4 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "bfeced32-ad27-43a7-bcbf-e422df18a155", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "pageViews | summarize PageViews=count(), Sessions=dcount(session_Id) by bin(timestamp, 1d) | sort by timestamp asc", "isOptional": true },
                    { "name": "ControlType", "value": "FrameControlChart", "isOptional": true },
                    { "name": "SpecificChart", "value": "Line", "isOptional": true },
                    { "name": "PartTitle", "value": "Page views & sessions per day", "isOptional": true },
                    { "name": "PartSubTitle", "value": "[parameters('appInsightsName')]", "isOptional": true },
                    {
                      "name": "Dimensions",
                      "value": {
                        "xAxis": { "name": "timestamp", "type": "datetime" },
                        "yAxis": [
                          { "name": "PageViews", "type": "long" },
                          { "name": "Sessions", "type": "long" }
                        ],
                        "splitBy": [],
                        "aggregation": "Sum"
                      },
                      "isOptional": true
                    },
                    { "name": "LegendOptions", "value": { "isEnabled": true, "position": "Bottom" }, "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              },
              {
                "position": { "x": 8, "y": 1, "colSpan": 4, "rowSpan": 4 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "482a0e12-a41d-402d-8294-f3320ad9e53a", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "union pageViews, customEvents | summarize events=count(), start=min(timestamp), stop=max(timestamp) by session_Id | extend dwellSec=datetime_diff('second', stop, start) | summarize Sessions=count(), MedianEventsPerSession=percentile(events,50), MedianDwellSec=percentile(dwellSec,50), AvgDwellSec=round(avg(dwellSec),1)", "isOptional": true },
                    { "name": "ControlType", "value": "AnalyticsGrid", "isOptional": true },
                    { "name": "SpecificChart", "isOptional": true },
                    { "name": "PartTitle", "value": "Engagement (per visit)", "isOptional": true },
                    { "name": "PartSubTitle", "value": "sessions · events/session · dwell time", "isOptional": true },
                    { "name": "Dimensions", "isOptional": true },
                    { "name": "LegendOptions", "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              },
              {
                "position": { "x": 0, "y": 5, "colSpan": 6, "rowSpan": 5 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "527e972e-d87f-4b2a-ba39-1894477a1151", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "customEvents | summarize Events=count(), Sessions=dcount(session_Id) by Event=name | sort by Events desc", "isOptional": true },
                    { "name": "ControlType", "value": "AnalyticsGrid", "isOptional": true },
                    { "name": "SpecificChart", "isOptional": true },
                    { "name": "PartTitle", "value": "Key events", "isOptional": true },
                    { "name": "PartSubTitle", "value": "custom events by name", "isOptional": true },
                    { "name": "Dimensions", "isOptional": true },
                    { "name": "LegendOptions", "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              },
              {
                "position": { "x": 6, "y": 5, "colSpan": 6, "rowSpan": 5 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "0e2c3f63-c9da-4b88-ac2b-1797094719ce", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "customEvents | where name == 'Input Changed' | summarize Changes=count() by Input=tostring(customDimensions.key) | sort by Changes desc", "isOptional": true },
                    { "name": "ControlType", "value": "AnalyticsGrid", "isOptional": true },
                    { "name": "SpecificChart", "isOptional": true },
                    { "name": "PartTitle", "value": "Most-adjusted inputs", "isOptional": true },
                    { "name": "PartSubTitle", "value": "which controls users touch", "isOptional": true },
                    { "name": "Dimensions", "isOptional": true },
                    { "name": "LegendOptions", "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              },
              {
                "position": { "x": 0, "y": 10, "colSpan": 4, "rowSpan": 4 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "cbd64276-0e1f-4528-bd12-afe381b549b9", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "customEvents | where name == 'Scenario Applied' | summarize Applied=count() by Scenario=tostring(customDimensions.scenarioId) | sort by Applied desc", "isOptional": true },
                    { "name": "ControlType", "value": "AnalyticsGrid", "isOptional": true },
                    { "name": "SpecificChart", "isOptional": true },
                    { "name": "PartTitle", "value": "Scenarios applied", "isOptional": true },
                    { "name": "PartSubTitle", "value": "preset shortcuts", "isOptional": true },
                    { "name": "Dimensions", "isOptional": true },
                    { "name": "LegendOptions", "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              },
              {
                "position": { "x": 4, "y": 10, "colSpan": 4, "rowSpan": 4 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "aeb59a2a-06ae-4f65-a944-c994e875e53d", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "customEvents | where name startswith 'Cost Center' | summarize Count=count() by Action=name | sort by Count desc", "isOptional": true },
                    { "name": "ControlType", "value": "AnalyticsGrid", "isOptional": true },
                    { "name": "SpecificChart", "isOptional": true },
                    { "name": "PartTitle", "value": "Cost-center actions", "isOptional": true },
                    { "name": "PartSubTitle", "value": "add · remove · update", "isOptional": true },
                    { "name": "Dimensions", "isOptional": true },
                    { "name": "LegendOptions", "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              },
              {
                "position": { "x": 8, "y": 10, "colSpan": 4, "rowSpan": 4 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "280578bf-3559-4e65-9bfc-ab0d4b124e48", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "customEvents | where name == 'Outbound Click' | summarize Clicks=count() by Target=tostring(customDimensions.label) | sort by Clicks desc", "isOptional": true },
                    { "name": "ControlType", "value": "AnalyticsGrid", "isOptional": true },
                    { "name": "SpecificChart", "isOptional": true },
                    { "name": "PartTitle", "value": "Outbound clicks", "isOptional": true },
                    { "name": "PartSubTitle", "value": "LinkedIn · GitHub", "isOptional": true },
                    { "name": "Dimensions", "isOptional": true },
                    { "name": "LegendOptions", "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              },
              {
                "position": { "x": 0, "y": 14, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "5d7ee16f-3b4a-4474-b81c-4a63362c42c8", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "pageViews | summarize Sessions=dcount(session_Id) by Country=client_CountryOrRegion | sort by Sessions desc | take 15", "isOptional": true },
                    { "name": "ControlType", "value": "AnalyticsGrid", "isOptional": true },
                    { "name": "SpecificChart", "isOptional": true },
                    { "name": "PartTitle", "value": "Top countries", "isOptional": true },
                    { "name": "PartSubTitle", "value": "sessions by geo", "isOptional": true },
                    { "name": "Dimensions", "isOptional": true },
                    { "name": "LegendOptions", "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              },
              {
                "position": { "x": 6, "y": 14, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "inputs": [
                    { "name": "resourceTypeMode", "isOptional": true },
                    { "name": "ComponentId", "value": "[parameters('appInsightsId')]", "isOptional": true },
                    { "name": "Scope", "value": "[variables('scope')]", "isOptional": true },
                    { "name": "PartId", "value": "7264e038-77c7-4b41-a3a3-c27c911c7cee", "isOptional": true },
                    { "name": "Version", "value": "2.0", "isOptional": true },
                    { "name": "TimeRange", "value": "P30D", "isOptional": true },
                    { "name": "DashboardId", "isOptional": true },
                    { "name": "DraftRequestParameters", "isOptional": true },
                    { "name": "Query", "value": "pageViews | summarize Sessions=dcount(session_Id) by Browser=client_Browser, OS=client_OS | sort by Sessions desc | take 20", "isOptional": true },
                    { "name": "ControlType", "value": "AnalyticsGrid", "isOptional": true },
                    { "name": "SpecificChart", "isOptional": true },
                    { "name": "PartTitle", "value": "Browser & OS", "isOptional": true },
                    { "name": "PartSubTitle", "value": "sessions by client", "isOptional": true },
                    { "name": "Dimensions", "isOptional": true },
                    { "name": "LegendOptions", "isOptional": true },
                    { "name": "IsQueryContainTimeRange", "value": false, "isOptional": true }
                  ],
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {},
                  "asset": { "idInputName": "ComponentId", "type": "ApplicationInsights" }
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "outputs": {
    "dashboardId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Portal/dashboards', parameters('dashboardName'))]"
    }
  }
}
